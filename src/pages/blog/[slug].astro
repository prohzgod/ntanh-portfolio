---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/globals.css';

export const prerender = true;

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} - Nguyen Tuan Anh`} description={post.data.description} type="article">
  <main class="min-h-screen bg-[#f1eee7] px-5 py-20 text-[#181612] sm:px-8 lg:px-10">
    <article class="mx-auto max-w-3xl">
      <a
        href="/blog/"
        class="font-mono text-xs font-black uppercase tracking-[0.16em] text-[#181612]/55 transition-colors hover:text-[#181612]"
      >
        Back to blog
      </a>
      <p class="mt-16 font-mono text-xs font-black uppercase tracking-[0.22em] text-[#181612]/40">
        {post.data.publishedAt.toLocaleDateString('en', {
          month: 'short',
          day: '2-digit',
          year: 'numeric',
        })}
      </p>
      <h1 class="mt-6 font-display text-4xl font-bold uppercase leading-[1.05] tracking-normal sm:text-6xl">
        {post.data.title}
      </h1>
      <p class="mt-6 text-xl font-semibold leading-relaxed text-[#181612]/65">
        {post.data.description}
      </p>
      <div class="prose-blog mt-12 border-t border-[#181612]/12 pt-10 text-lg font-semibold leading-relaxed text-[#181612]/72">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
